# ── Desarrollo local ────────────────────────────────────────
# Copiar a .env y rellenar. Para frontend ver app/.env.example.

# Supabase local (supabase start) o proyecto cloud
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJ...        # supabase status → anon key
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # solo backend/functions, NUNCA en frontend
SUPABASE_DB_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Email (Resend) — para Edge Functions en local
RESEND_API_KEY=re_xxx
EMAIL_FROM=Ensayo <notificaciones@ensayoapp.es>

# Web Push VAPID — generar: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ensayoapp.es

# Superadmin inicial (seed)
SUPERADMIN_EMAIL=you@example.com
