# Variables OPCIONALES para el stack local (docker compose las lee si existen en .env).
# Sin este fichero todo funciona: email y push quedan desactivados en local.

# Google OAuth en local (opcional — el seed crea usuarios por password)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Email real desde local (opcional)
RESEND_API_KEY=
EMAIL_FROM=Ensayo <notificaciones@tudominio.es>

# Web Push en local (opcional) — npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@localhost
