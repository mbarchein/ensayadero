# OPTIONAL variables for the local stack (docker compose reads them from .env if present).
# Everything works without this file: email and push stay disabled locally.

# Host used to build the app/API URLs. Default localhost. To test from a phone
# on the same Wi-Fi, set it to your machine's LAN IP, then `docker compose up -d`
# and open http://<that-ip>:5173 on the phone.
#   DEV_HOST=192.168.0.11

# Google OAuth locally (optional — the seed creates password users)
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Real email from local (optional)
RESEND_API_KEY=
EMAIL_FROM=Ensayadero <notifications@yourdomain.es>

# Web Push locally (optional) — npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@localhost

# Cloudflare Turnstile CAPTCHA locally (optional). No keys = disabled.
# For testing, Cloudflare publishes "always passes" keys:
#   site=1x00000000000000000000AA  secret=1x0000000000000000000000000000000AA
TURNSTILE_CAPTCHA_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
