# Production environment for the Docker Swarm stack (docker-stack.yml).
# Copy to prod.env, fill in, then:  chmod 600 prod.env
# NEVER commit prod.env. Load it before deploying:
#   set -a; source prod.env; set +a

# ── Public URLs (what browsers hit; behind your TLS reverse proxy) ──────
PUBLIC_APP_URL=https://ensayadero.es
PUBLIC_API_URL=https://api.ensayadero.es

# Host ports the stack publishes (put a TLS proxy in front of these)
APP_PORT=8080
API_PORT=8000

# ── Images (registry prefix + tag). For a single-node swarm you can build
#    locally and leave these as-is. For multi-node, push to a registry. ──
IMAGE_PREFIX=ensayadero
TAG=latest

# Bump after editing docker/gateway.conf or docker/db-init.prod.sh
CONFIG_VERSION=v1

# ── Secrets ─────────────────────────────────────────────────────────────
# Database password (used by Postgres AND the service connection URLs).
DB_PASSWORD=change-me-long-random

# JWT secret (min 32 chars). Generate: openssl rand -hex 32
JWT_SECRET=change-me-min-32-characters-long-secret

# API keys derived from JWT_SECRET. Generate with:
#   node docker/gen-keys.mjs "$JWT_SECRET"
ANON_KEY=
SERVICE_ROLE_KEY=

# Realtime secrets. Generate: openssl rand -hex 32 (base) / exactly 16 bytes (enc)
REALTIME_SECRET_KEY_BASE=change-me-64-char-random
REALTIME_ENC_KEY=change-me-16char

# ── Email (SMTP, e.g. Resend) ───────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxx
SMTP_ADMIN_EMAIL=noreply@ensayadero.es
EMAIL_FROM=Ensayadero <noreply@ensayadero.es>
RESEND_API_KEY=re_xxx

# ── Web Push (VAPID). Generate: npx web-push generate-vapid-keys ────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@ensayadero.es

# ── OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_OAUTH_ENABLED=false
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_ENABLED=false
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# ── CAPTCHA (Cloudflare Turnstile, optional) ────────────────────────────
TURNSTILE_CAPTCHA_ENABLED=false
TURNSTILE_SECRET=
# The site key (public) is baked into the frontend at build time — see DEPLOY.md.
TURNSTILE_SITE_KEY=
