# Copiar a terraform.tfvars y rellenar. NUNCA commitear terraform.tfvars.

project_name = "ensayo"
environment  = "prod"

# Supabase — token: https://supabase.com/dashboard/account/tokens
supabase_access_token = "sbp_xxx"
supabase_org_id       = "tu-org-slug"
supabase_region       = "eu-west-3"
# supabase_db_password = null  # se genera si se omite

# Google OAuth — crear manual en https://console.cloud.google.com/apis/credentials
# Redirect URI: ver output google_oauth_redirect_uri tras primer apply
google_oauth_client_id     = "xxx.apps.googleusercontent.com"
google_oauth_client_secret = "GOCSPX-xxx"

# Meta/Facebook OAuth (login con cuentas Instagram vinculadas) — OPCIONAL.
# Crear app en https://developers.facebook.com (ver BOOTSTRAP). Dejar vacío
# para deshabilitar el provider.
facebook_oauth_client_id     = ""
facebook_oauth_client_secret = ""

# Seguridad de contraseñas: comprobación de filtradas (HaveIBeenPwned).
# Requiere plan Pro de Supabase. Dejar en false en free tier.
password_hibp_enabled = false

# Cloudflare — token con Pages:Edit, DNS:Edit, Zone:Read
cloudflare_api_token  = "xxx"
cloudflare_account_id = "xxx"
domain                = "ensayoapp.es"
app_subdomain         = "app"

# Resend — añadir dominio en https://resend.com/domains y copiar records aquí
resend_api_key      = "re_xxx"
resend_dkim_records = [
  # { name = "resend._domainkey", type = "TXT", content = "p=MIGf..." },
  # { name = "send", type = "MX", content = "feedback-smtp.eu-west-1.amazonses.com", priority = 10 },
  # { name = "send", type = "TXT", content = "v=spf1 include:amazonses.com ~all" },
]

# GitHub — token con repo + secrets
github_token = "ghp_xxx"
github_owner = "tu-usuario"
github_repo  = "ensayo"
