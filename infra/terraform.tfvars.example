# Copy to terraform.tfvars and fill in. NEVER commit terraform.tfvars.

project_name = "ensayo"
environment  = "prod"

# Supabase — token: https://supabase.com/dashboard/account/tokens
supabase_access_token = "sbp_xxx"
supabase_org_id       = "your-org-slug"
supabase_region       = "eu-west-3"
# supabase_db_password = null  # generated if omitted

# Google OAuth — create manually at https://console.cloud.google.com/auth/clients
# Redirect URI: see the google_oauth_redirect_uri output after the first apply
google_oauth_client_id     = "xxx.apps.googleusercontent.com"
google_oauth_client_secret = "GOCSPX-xxx"

# Meta/Facebook OAuth (login with linked Instagram accounts) — OPTIONAL.
# Create the app at https://developers.facebook.com (see BOOTSTRAP). Leave empty
# to disable the provider.
facebook_oauth_client_id     = ""
facebook_oauth_client_secret = ""

# Password security: leaked-password check (HaveIBeenPwned).
# Requires the Supabase Pro plan. Keep false on free tier.
password_hibp_enabled = false

# Cloudflare Turnstile CAPTCHA (anti-bot on auth forms) — OPTIONAL.
# true = Terraform creates the widget and wires site key + secret automatically
# (needs Turnstile:Edit on the Cloudflare token). false = no CAPTCHA.
turnstile_enabled = false

# Web Push VAPID public key (frontend). Generate the keypair with:
#   npx web-push generate-vapid-keys   (or node crypto offline — see BOOTSTRAP)
# Public key here; private key goes to the Edge Function secret VAPID_PRIVATE_KEY.
vapid_public_key = ""

# Cloudflare — Custom API token. Permissions (scope -> group -> access):
#   Account -> Cloudflare Pages   -> Edit
#   Account -> Turnstile          -> Edit   (only if turnstile_enabled = true)
#   Zone    -> DNS                -> Edit
#   Zone    -> Zone               -> Read
#   Zone    -> Single Redirect    -> Edit   (only if redirect_root_to_app = true)
cloudflare_api_token  = "xxx"
cloudflare_account_id = "xxx"
domain                = "ensayoapp.es"
app_subdomain         = "app"
redirect_root_to_app  = true # 301 the apex domain -> app subdomain (needs Zone:Single Redirect:Edit on the token)

# Resend — add the domain at https://resend.com/domains and copy the records here
resend_api_key      = "re_xxx"
resend_dkim_records = [
  # { name = "resend._domainkey", type = "TXT", content = "p=MIGf..." },
  # { name = "send", type = "MX", content = "feedback-smtp.eu-west-1.amazonses.com", priority = 10 },
  # { name = "send", type = "TXT", content = "v=spf1 include:amazonses.com ~all" },
]

# GitHub — token with repo + secrets
github_token = "ghp_xxx"
github_owner = "your-username"
github_repo  = "ensayo"
